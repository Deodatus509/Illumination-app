rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data 
        : {};
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (getUserData().get('role', '') == 'admin' || 
        ('email' in request.auth.token && request.auth.token.email == "dieudonnejose41@gmail.com" && 
         'email_verified' in request.auth.token && request.auth.token.email_verified == true));
    }
    
    function isEditor() {
      return isAuthenticated() && (getUserData().get('role', '') == 'editor' || isAdmin());
    }
    
    function isAuthor() {
      return isAuthenticated() && (getUserData().get('role', '') == 'author' || isEditor());
    }
    
    function isSupporteur() {
      return isAuthenticated() && (getUserData().get('role', '') == 'supporteur' || isAdmin());
    }
    
    function isPremium() {
      return isAuthenticated() && (getUserData().get('isPremium', false) == true || isAdmin());
    }
    
    function isEnrolled(courseId) {
      return exists(/databases/$(database)/documents/enrollments/$(request.auth.uid + '_' + courseId));
    }

    // ===============================================================
    // Collections (9 Core Collections)
    // ===============================================================

    // 1. Users (Public Profile)
    match /users/{userId} {
      // Public profiles are readable by anyone
      allow read: if true;
      // Users can create their own public profile
      allow create: if isAuthenticated() && isOwner(userId);
      // Users can update their own public profile, but cannot change their role or isPremium status unless admin
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.isPremium == resource.data.isPremium) || isAdmin();
      allow delete: if isAdmin();
      
      // 1.1 Private User Data
      match /private/profile {
        // Only the owner and admins can read private data
        allow read: if isOwner(userId) || isAdmin();
        // Only the owner can create/update their private data
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    // 2. Blog Posts
    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if isAuthor();
    }

    // 3. Library
    match /library/{itemId} {
      allow read: if true;
      allow write: if isAuthor();
    }

    // 4. Courses
    match /courses/{courseId} {
      allow read: if true;
      allow write: if isAuthor();
    }

    // 5. Lessons
    match /lessons/{lessonId} {
      allow read: if isAuthenticated();
      allow write: if isAuthor();
    }

    // 6. Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isEditor();
    }

    // 7. Enrollments
    match /enrollments/{enrollmentId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow delete: if isAdmin();
    }

    // 8. Subscriptions
    match /subscriptions/{subscriptionId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId || isAdmin();
      allow write: if isAdmin(); // Admin or secure backend function creates this
    }

    // 9. Transactions
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId || isAdmin();
      allow write: if isAdmin(); // Admin or secure backend function creates this
    }

    // 10. Interactions
    match /interactions/{interactionId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid || isAdmin();
    }

    // 11. Comments
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() && (
        // Allow author to update content
        (request.resource.data.authorId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['content'])) ||
        // Allow anyone authenticated to update likes/dislikes by exactly 1 or -1
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes', 'dislikes']) &&
         (!('likes' in request.resource.data.diff(resource.data).affectedKeys()) || math.abs(request.resource.data.likes - resource.data.likes) == 1) &&
         (!('dislikes' in request.resource.data.diff(resource.data).affectedKeys()) || math.abs(request.resource.data.dislikes - resource.data.dislikes) == 1))
      ) || isAdmin();
      allow delete: if isAuthenticated() && resource.data.authorId == request.auth.uid || isAdmin();
    }

    // 12. Comment Reactions
    match /commentReactions/{reactionId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid || isAdmin();
    }

    // 13. Post Reactions
    match /postReactions/{reactionId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid || isAdmin();
    }

    // 14. Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    // 15. Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 16. Page Banners
    match /page_banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 17. Carousels
    match /carousels/{carouselId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 18. Conversations
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participants || isSupporteur());
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.participants || isSupporteur());
      allow delete: if isAdmin();
    }

    // 18.1 Messages
    match /messages/{messageId} {
      allow read: if isAuthenticated() && (
        isSupporteur() || 
        ('conversation_id' in resource.data && exists(/databases/$(database)/documents/conversations/$(resource.data.conversation_id)) && request.auth.uid in get(/databases/$(database)/documents/conversations/$(resource.data.conversation_id)).data.participants)
      );
      allow create: if (isAuthenticated() && 'sender_id' in request.resource.data && request.auth.uid == request.resource.data.sender_id && (
        isSupporteur() ||
        ('conversation_id' in request.resource.data && exists(/databases/$(database)/documents/conversations/$(request.resource.data.conversation_id)) && request.auth.uid in get(/databases/$(database)/documents/conversations/$(request.resource.data.conversation_id)).data.participants)
      )) || (!isAuthenticated() && request.resource.data.get('is_guest', false) == true);
      allow update: if isAuthenticated() && (
        isSupporteur() ||
        ('conversation_id' in resource.data && exists(/databases/$(database)/documents/conversations/$(resource.data.conversation_id)) && request.auth.uid in get(/databases/$(database)/documents/conversations/$(resource.data.conversation_id)).data.participants)
      ) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['is_read']);
      allow delete: if isAdmin();
    }

    // 19. Sanctum Lucis - Spiritual Quotes
    match /spiritual_quotes/{quoteId} {
      allow read: if true;
      allow write: if isAuthor();
    }

    // 20. Sanctum Lucis - Consultations
    match /consultation_services/{serviceId} {
      allow read: if true;
      allow write: if isAuthor();
    }

    match /consultations/{consultationId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.user_id || isAuthor());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.user_id;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.user_id || isAuthor());
      allow delete: if isAdmin();
    }

    match /consultation_files/{fileId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAuthor();
    }

    match /consultation_notes/{noteId} {
      allow read, write: if isAuthor();
    }

    match /consultation_appointments/{appointmentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthor();
    }

    match /consultation_history/{historyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    // 21. Sanctum Lucis - Meditation
    match /meditation_classes/{classId} {
      allow read: if true;
      allow write: if isAuthor();
    }

    match /meditation_members/{memberId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.user_id;
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.user_id || isAuthor());
    }

    match /meditation_conversations/{conversationId} {
      allow read: if isAuthenticated();
      allow write: if isAuthor();
    }

    match /meditation_messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.sender_id;
      allow update, delete: if isAuthor();
    }

    match /meditation_history/{historyId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if false;
    }

    match /meditation_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if isAuthor();
    }

    match /meditation_files/{fileId} {
      allow read: if isAuthenticated();
      allow write: if isAuthor();
    }

    match /meditation_audios/{audioId} {
      allow read: if isAuthenticated();
      allow write: if isAuthor();
    }

    match /meditation_videos/{videoId} {
      allow read: if isAuthenticated();
      allow write: if isAuthor();
    }

    match /meditation_events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isAuthor();
    }

    match /meditation_live_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow write: if isAuthor();
    }

    match /meditation_live_sessions/{sessionId}/reactions/{reactionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAuthor();
    }
    
    match /meditation_live_sessions/{sessionId}/presence/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAuthenticated() && request.auth.uid == userId;
    }

    // 22. Sanctum Lucis - Rituals
    match /rituals/{ritualId} {
      allow read: if true;
      allow write: if isEditor();
    }

    match /ritual_submissions/{submissionId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.submitted_by || isEditor());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.submitted_by;
      allow update: if isEditor();
      allow delete: if isAdmin();
    }

    match /ritual_participants/{participantId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // 23. Global & User Features
    match /favorites/{favoriteId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    match /spiritual_profiles/{profileId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /spiritual_journal/{entryId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 24. Author Requests
    match /author_requests/{requestId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.user_id || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.user_id;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
