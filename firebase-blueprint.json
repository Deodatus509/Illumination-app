{
  "entities": {
    "UserPublic": {
      "title": "UserPublic",
      "description": "Public user profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "bio": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "prestataire", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "createdAt"]
    },
    "UserPrivate": {
      "title": "UserPrivate",
      "description": "Sensitive user information accessible only to the user and admins",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "language": { "type": "string", "enum": ["FR", "KH", "EN"] },
        "theme": { "type": "string", "enum": ["light", "dark"] },
        "notificationPreferences": {
          "type": "object",
          "properties": {
            "push": { "type": "boolean" },
            "sms": { "type": "boolean" },
            "email": { "type": "boolean" }
          }
        },
        "lastLogin": { "type": "string", "format": "date-time" },
        "markedForDeletion": { "type": "boolean" },
        "stripeCustomerId": { "type": "string" },
        "monCashId": { "type": "string" }
      },
      "required": ["email", "isVerified", "language", "theme", "notificationPreferences", "lastLogin", "markedForDeletion"]
    },
    "Post": {
      "title": "Post",
      "description": "Blog post with esoteric teachings",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "mediaUrl": { "type": "string" },
        "isFree": { "type": "boolean" },
        "previewContent": { "type": "string" },
        "author": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "isFree", "previewContent", "author"]
    },
    "LibraryItem": {
      "title": "LibraryItem",
      "description": "Document or book in the library",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "fileUrl": { "type": "string" },
        "coverUrl": { "type": "string" },
        "pages": { "type": "number" },
        "format": { "type": "string", "enum": ["PDF", "Epub"] }
      },
      "required": ["title", "description", "price", "fileUrl", "coverUrl"]
    },
    "Course": {
      "title": "Course",
      "description": "Esoteric course or formation",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "difficulty": { "type": "string" },
        "price": { "type": "number" },
        "coverImage": { "type": "string" },
        "moduleIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["name", "description", "difficulty", "price", "coverImage"]
    },
    "Lesson": {
      "title": "Lesson",
      "description": "Individual lesson within a course",
      "type": "object",
      "properties": {
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "order": { "type": "number" },
        "content": { "type": "string" },
        "resources": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["courseId", "title", "order", "content"]
    },
    "Enrollment": {
      "title": "Enrollment",
      "description": "Student enrollment in a course",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "courseId": { "type": "string" },
        "status": { "type": "string", "enum": ["en cours", "terminé"] },
        "progress": { "type": "number" },
        "expirationDate": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "courseId", "status", "progress"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "Premium subscription",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["Mensuel", "Annuel"] },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "isActive": { "type": "boolean" }
      },
      "required": ["userId", "type", "startDate", "endDate", "isActive"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "method": { "type": "string", "enum": ["MonCash", "Stripe", "PayPal"] },
        "status": { "type": "string", "enum": ["success", "pending", "failed"] },
        "productId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "currency", "method", "status", "productId"]
    },
    "Interaction": {
      "title": "Interaction",
      "description": "Social interaction like comment or like",
      "type": "object",
      "properties": {
        "targetId": { "type": "string", "description": "postId or lessonId" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "comment"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["targetId", "userId", "type", "timestamp"]
    },
    "Comment": {
      "title": "Comment",
      "description": "Blog post comment",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "author": { "type": "string" },
        "authorId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "likes": { "type": "number" },
        "dislikes": { "type": "number" }
      },
      "required": ["postId", "author", "authorId", "content", "createdAt", "likes", "dislikes"]
    },
    "CommentReaction": {
      "title": "CommentReaction",
      "description": "User reaction to a comment",
      "type": "object",
      "properties": {
        "commentId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "dislike"] }
      },
      "required": ["commentId", "userId", "type"]
    },
    "PostReaction": {
      "title": "PostReaction",
      "description": "User reaction to a post",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "inspiring"] }
      },
      "required": ["postId", "userId", "type"]
    },
    "PageBanner": {
      "title": "PageBanner",
      "description": "Banner image for a specific page",
      "type": "object",
      "properties": {
        "pageName": { "type": "string" },
        "imageUrl": { "type": "string" },
        "storagePath": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "updatedBy": { "type": "string" }
      },
      "required": ["pageName", "imageUrl", "storagePath", "updatedAt", "updatedBy"]
    },
    "Carousel": {
      "title": "Carousel",
      "description": "Image carousel for pages",
      "type": "object",
      "properties": {
        "page": { "type": "string", "enum": ["home", "academy", "library", "blog"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "link": { "type": "string" },
        "orderIndex": { "type": "number" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["page", "title", "description", "imageUrl", "orderIndex", "isActive", "createdAt", "updatedAt"]
    },
    "SpiritualQuote": {
      "title": "SpiritualQuote",
      "description": "Spiritual quotes for Sanctum Lucis",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "author": { "type": "string" },
        "category": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "created_by": { "type": "string" },
        "is_active": { "type": "boolean" }
      },
      "required": ["text", "author", "is_active"]
    },
    "ConsultationService": {
      "title": "ConsultationService",
      "description": "Available consultation services",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "is_active": { "type": "boolean" }
      },
      "required": ["title", "description", "price", "is_active"]
    },
    "Consultation": {
      "title": "Consultation",
      "description": "Consultation requests",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "service_id": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "completed"] },
        "created_at": { "type": "string", "format": "date-time" },
        "assigned_to": { "type": "string" }
      },
      "required": ["user_id", "service_id", "message", "status", "created_at"]
    },
    "ConsultationMessage": {
      "title": "ConsultationMessage",
      "description": "Messages within a consultation",
      "type": "object",
      "properties": {
        "consultation_id": { "type": "string" },
        "sender_id": { "type": "string" },
        "message": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["consultation_id", "sender_id", "message", "created_at"]
    },
    "MeditationClass": {
      "title": "MeditationClass",
      "description": "Meditation classes",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "start_date": { "type": "string", "format": "date-time" },
        "is_active": { "type": "boolean" }
      },
      "required": ["title", "description", "price", "start_date", "is_active"]
    },
    "MeditationMember": {
      "title": "MeditationMember",
      "description": "Members of a meditation class",
      "type": "object",
      "properties": {
        "class_id": { "type": "string" },
        "user_id": { "type": "string" },
        "joined_at": { "type": "string", "format": "date-time" }
      },
      "required": ["class_id", "user_id", "joined_at"]
    },
    "MeditationMessage": {
      "title": "MeditationMessage",
      "description": "Messages within a meditation class",
      "type": "object",
      "properties": {
        "class_id": { "type": "string" },
        "user_id": { "type": "string" },
        "message": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["class_id", "user_id", "message", "created_at"]
    },
    "Ritual": {
      "title": "Ritual",
      "description": "Rituals available in Sanctum Lucis",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "steps": { "type": "array", "items": { "type": "string" } },
        "created_by": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "active"] },
        "price": { "type": "number" },
        "is_active": { "type": "boolean" }
      },
      "required": ["title", "description", "steps", "created_by", "status", "price", "is_active"]
    },
    "RitualSubmission": {
      "title": "RitualSubmission",
      "description": "Rituals submitted by members",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "steps": { "type": "array", "items": { "type": "string" } },
        "submitted_by": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected", "active"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "steps", "submitted_by", "status", "created_at"]
    }
  },
  "firestore": {
    "comments/{commentId}": { "schema": { "$ref": "#/entities/Comment" }, "description": "Blog comments" },
    "commentReactions/{reactionId}": { "schema": { "$ref": "#/entities/CommentReaction" }, "description": "User reactions to comments" },
    "postReactions/{reactionId}": { "schema": { "$ref": "#/entities/PostReaction" }, "description": "User reactions to posts" },
    "users/{userId}": { "schema": { "$ref": "#/entities/UserPublic" }, "description": "Public user profiles" },
    "users/{userId}/private/profile": { "schema": { "$ref": "#/entities/UserPrivate" }, "description": "Private user data" },
    "posts/{postId}": { "schema": { "$ref": "#/entities/Post" }, "description": "Blog posts" },
    "library/{itemId}": { "schema": { "$ref": "#/entities/LibraryItem" }, "description": "Library documents" },
    "courses/{courseId}": { "schema": { "$ref": "#/entities/Course" }, "description": "Courses" },
    "lessons/{lessonId}": { "schema": { "$ref": "#/entities/Lesson" }, "description": "Course lessons" },
    "enrollments/{enrollmentId}": { "schema": { "$ref": "#/entities/Enrollment" }, "description": "Student enrollments" },
    "subscriptions/{subscriptionId}": { "schema": { "$ref": "#/entities/Subscription" }, "description": "Premium subscriptions" },
    "transactions/{transactionId}": { "schema": { "$ref": "#/entities/Transaction" }, "description": "Financial transactions" },
    "interactions/{interactionId}": { "schema": { "$ref": "#/entities/Interaction" }, "description": "Social interactions" },
    "page_banners/{bannerId}": { "schema": { "$ref": "#/entities/PageBanner" }, "description": "Page banners" },
    "carousels/{carouselId}": { "schema": { "$ref": "#/entities/Carousel" }, "description": "Image carousels" },
    "spiritual_quotes/{quoteId}": { "schema": { "$ref": "#/entities/SpiritualQuote" }, "description": "Spiritual quotes" },
    "consultation_services/{serviceId}": { "schema": { "$ref": "#/entities/ConsultationService" }, "description": "Consultation services" },
    "consultations/{consultationId}": { "schema": { "$ref": "#/entities/Consultation" }, "description": "Consultation requests" },
    "consultation_messages/{messageId}": { "schema": { "$ref": "#/entities/ConsultationMessage" }, "description": "Consultation messages" },
    "meditation_classes/{classId}": { "schema": { "$ref": "#/entities/MeditationClass" }, "description": "Meditation classes" },
    "meditation_members/{memberId}": { "schema": { "$ref": "#/entities/MeditationMember" }, "description": "Meditation class members" },
    "meditation_messages/{messageId}": { "schema": { "$ref": "#/entities/MeditationMessage" }, "description": "Meditation class messages" },
    "rituals/{ritualId}": { "schema": { "$ref": "#/entities/Ritual" }, "description": "Rituals" },
    "ritual_submissions/{submissionId}": { "schema": { "$ref": "#/entities/RitualSubmission" }, "description": "Ritual submissions" }
  }
}
